# API Token
API_TOKEN=your-api-token-here

# MongoDB Configuration
MONGODB_URI=your-mongodb-connection-string
MONGODB_DATABASE=your-database-name

# SMTP Configuration
SMTP_SENDER_EMAIL=your-email@example.com
SMTP_SENDER_PASSWORD=your-smtp-password

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VERTEX_PROJECT=your-vertex-project-id

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=your-cloudfront-key-pair-id
AWS_CLOUDFRONT_PRIVATE_KEY_PATH=cloudfront-private-key.pem

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

